# ---------- App ----------
ENV=development
DEBUG=True

# ---------- JWT ----------
JWT_SECRET_KEY=change_this_to_a_long_random_secret

# ---------- Firebase ----------
FIREBASE_CREDENTIALS_PATH=app/firebase/service_account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ---------- Razorpay ----------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# ---------- Twelve Data (Forex: XAU/USD, EUR/USD) ----------
TWELVE_DATA_API_KEY=your_twelve_data_api_key

# ---------- CoinGecko (Crypto: BTCUSDT, SOLUSDT) — free tier needs no key ----------
COINGECKO_API_KEY=

# ---------- Angel One SmartAPI (Stocks: ITC, WIPRO, HDFCBANK, NIFTY50) ----------
ANGEL_ONE_API_KEY=your_angel_one_api_key
ANGEL_ONE_CLIENT_ID=your_client_id
ANGEL_ONE_PASSWORD=your_password
ANGEL_ONE_TOTP_SECRET=your_totp_secret

# ---------- Anthropic (AI Analysis Engine) ----------
ANTHROPIC_API_KEY=your_anthropic_api_key

# ---------- CORS ----------
ALLOWED_ORIGINS=["http://localhost:3000"]
